# OpenAI-compatible provider
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Alternative providers (OpenAI-compatible)
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Multi OpenAI-compatible providers (JSON array)
# OPENAI_COMPAT_PROVIDERS_JSON=[
#   {"name":"kimi","base_url":"https://api.moonshot.cn/v1","model":"moonshot-v1-8k","api_key_env":"KIMI_API_KEY"},
#   {"name":"glm","base_url":"https://open.bigmodel.cn/api/paas/v4","model":"glm-4.5","api_key_env":"GLM_API_KEY"}
# ]

# Role-based preferred provider map (JSON object)
# ROLE_PROVIDER_MAP_JSON={"author":"kimi","editor":"glm","reviewer:value":"glm"}

# Ollama (local, no key needed)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:30b

# Default model
DEFAULT_MODEL=gpt-4o-mini

# Budget (USD) per run
DEFAULT_BUDGET=1.0

# Max rounds per pipeline stage
DEFAULT_MAX_ROUNDS=6

# Database path
DB_PATH=./refinery.db
